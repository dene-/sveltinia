{
  "name": "sveltinia-monorepo",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p packages/sveltinia/tsconfig.json --noEmit",
    "build": "npm run typecheck && npm run build -w sveltinia && npm run docs:build",
    "docs:dev": "vitepress dev apps/docs",
    "docs:build": "vitepress build apps/docs"
  },
  "devDependencies": {"@types/node":"^22.10.0", "typescript":"^5.7.2", "vitest":"^2.1.8", "vitepress":"^1.5.0", "svelte":"^5.16.0"}
}
