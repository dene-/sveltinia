{
  "name": "sveltinia-monorepo",
  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p packages/sveltinia/tsconfig.json --noEmit",
    "build": "yarn typecheck && yarn workspace sveltinia build && yarn docs:build",
    "docs:dev": "vitepress dev apps/docs",
    "docs:build": "vitepress build apps/docs"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "vitepress": "^1.5.0",
    "svelte": "^5.16.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
